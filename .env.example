# Copy to .env and fill in. .env is gitignored.

# --- App ---
PORT=8191
NEXTAUTH_URL=http://localhost:8191
# Auth.js session secret — generate: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# --- Database (Drizzle + postgres.js) ---
# NOTE: no ?schema= param (that is Prisma-only and breaks postgres.js).
DATABASE_URL=postgresql://dora:dora@localhost:5432/dora

# --- Secrets encryption ---
# 32-byte base64 key for AES-256-GCM encryption of integration tokens.
# generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=change-me-32-byte-base64-key

# --- Bootstrap admin (seeded by scripts/seed.mjs) ---
BOOTSTRAP_ADMIN_EMAIL=admin@dora.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# --- Azure Entra ID SSO (optional; enables the provider when set) ---
AUTH_ENTRA_TENANT_ID=
AUTH_ENTRA_CLIENT_ID=
AUTH_ENTRA_CLIENT_SECRET=

# --- GitHub OAuth (optional) ---
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# --- Integrations (configured in-app via Settings; these are fallbacks) ---
JIRA_BASE_URL=
